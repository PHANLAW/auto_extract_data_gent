########################################
# APPLICATION CONFIGURATION
########################################
APP_NAME=Image Processing Agent
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

########################################
# SERVER CONFIGURATION
########################################
HOST=0.0.0.0
PORT=8000
API_V1_PREFIX=/api/v1

########################################
# AZURE OPENAI CONFIGURATION
########################################
# BẮT BUỘC: Azure OpenAI API Key
AZURE_OPENAI_API_KEY=your-azure-openai-key-here
# BẮT BUỘC: Azure OpenAI Endpoint (e.g., https://your-resource-name.openai.azure.com)
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
# API Version (thường không cần đổi)
AZURE_OPENAI_API_VERSION=2024-02-15-preview
# Tên deployment của model GPT-4 Vision (e.g., gpt-4o-mini, gpt-4o)
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

########################################
# SPORT API (Hệ thống API của bạn)
########################################
# BẮT BUỘC: Base URL của Sport API
SPORT_API_BASE_URL=https://your-sport-api.com
# BẮT BUỘC: Username và Password để login và lấy access_token
SPORT_API_USERNAME=your-username
SPORT_API_PASSWORD=your-password
# TÙY CHỌN: API Key (nếu dùng token cố định thay vì login)
SPORT_API_KEY=

########################################
# DATA SOURCE CONFIGURATION
########################################
# Chế độ nguồn dữ liệu: 'local' hoặc 'blob_storage'
# - local: Đọc folder từ LOCAL_DATA_PATH (data/)
# - blob_storage: Đọc folder từ Azure Blob Storage
DATA_SOURCE_MODE=local
# Đường dẫn folder data local (chỉ dùng khi DATA_SOURCE_MODE=local)
LOCAL_DATA_PATH=data

########################################
# AZURE BLOB STORAGE CONFIGURATION
########################################
# BẮT BUỘC nếu DATA_SOURCE_MODE=blob_storage: Connection string của Azure Storage Account
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# BẮT BUỘC nếu DATA_SOURCE_MODE=blob_storage: Tên container trong Blob Storage
AZURE_BLOB_CONTAINER_NAME=image-folders
# TÙY CHỌN: Prefix cho các blob (e.g., "raw-images")
AZURE_BLOB_PREFIX=
# Đường dẫn tạm để download folder từ blob khi xử lý
AZURE_BLOB_DOWNLOAD_PATH=temp_blob_downloads

########################################
# AUTO PROCESSING & TRACKER
########################################
# File lưu trạng thái đã xử lý (để tránh xử lý lại)
TRACKER_STATE_FILE=tracker_state.json
# Chỉ xử lý folder mới (true) hay xử lý lại tất cả (false)
TRACKER_ONLY_NEW=true
# Khoảng thời gian giữa các lần check tự động (giây) - chỉ áp dụng khi blob_storage
AUTO_PROCESS_INTERVAL=300

########################################
# IMAGE PROCESSING SETTINGS
########################################
# Có cắt phần trên của ảnh để tập trung vào thanh địa chỉ không
USE_CROP=true
# Tỉ lệ cắt phần trên của ảnh (0.0 - 1.0)
CROP_RATIO=0.13
# Các phần mở rộng của file ảnh được xử lý (phân cách bằng dấu phẩy)
IMAGE_EXTENSIONS=.png,.jpg,.jpeg,.bmp,.gif

########################################
# ERROR / RETRY FILE SETTINGS
########################################
# Tên file lưu các URL không tìm thấy detected_link_id
RETRY_FILE=retry_failed.json
# Định dạng file retry: 'json' hoặc 'csv'
RETRY_FILE_FORMAT=json

########################################
# LOGGING SETTINGS
########################################
# Mức độ log: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Đường dẫn file log
LOG_FILE=logs/app.log
